# ngrx-store-localstorage hasn't shipped a v21 yet (latest is 20.1.0,
# peer-requires @angular/common ^20). The lib works fine at runtime on
# Angular 21 — it's a single meta-reducer that only touches localStorage
# and NgRx ActionReducer. Override the peer-dep gate so `npm ci` doesn't
# bail. Remove once ngrx-store-localstorage ships v21 OR once we replace
# it during the upcoming NgRx selectSignal migration.
legacy-peer-deps=true
