# See http://help.github.com/ignore-files/ for more about ignoring files.

# compiled output
/dist
apps/*/dist
/tmp
/out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# Config file with sensitive information
.env

.angular
kendo-ui-license.txt

.nx/cache
.playwright-mcp

# Magic Eden archive data (GBs)
z_extra/magic-eden-archive.zip
z_extra/magic-eden-archive/magic-eden-data-dump/

# Playwright artifacts
apps/*/playwright-report
apps/*/test-results
apps/*/.playwright

# Claude Code transient scheduler state (see also ~/.gitignore_global)
.claude/scheduled_tasks.lock
