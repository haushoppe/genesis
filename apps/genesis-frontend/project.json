{
  "name": "genesis-frontend",
  "projectType": "application",
  "sourceRoot": "apps/genesis-frontend/src",
  "prefix": "app",
  "targets": {
    "build": {
      "executor": "@nrwl/angular:webpack-browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/genesis-frontend",
        "index": "apps/genesis-frontend/src/index.html",
        "main": "apps/genesis-frontend/src/main.ts",
        "polyfills": "apps/genesis-frontend/src/polyfills.ts",
        "tsConfig": "apps/genesis-frontend/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": ["apps/genesis-frontend/src/assets", "apps/genesis-frontend/src/x"],
        "styles": [
          "node_modules/@fontsource/yantramanav/300.css",
          "node_modules/@fontsource/yantramanav/500.css",
          "node_modules/@fontsource/yantramanav/700.css",
          "node_modules/@fontsource/merriweather/300.css",
          "node_modules/@fontsource/merriweather/400.css",
          "node_modules/bootstrap-icons/font/bootstrap-icons.css",
          "apps/genesis-frontend/src/styles.scss"],
        "scripts": [],
        "customWebpackConfig": {
          "path": "apps/genesis-frontend/webpack.config.js"
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "3mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "fileReplacements": [
            {
              "replace": "apps/genesis-frontend/src/environments/environment.ts",
              "with": "apps/genesis-frontend/src/environments/environment.prod.ts"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@nrwl/angular:webpack-dev-server",
      "options": {
        "port": 4201
      },
      "configurations": {
        "production": {
          "browserTarget": "genesis-frontend:build:production"
        },
        "development": {
          "browserTarget": "genesis-frontend:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "genesis-frontend:build"
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": ["apps/genesis-frontend/**/*.ts", "apps/genesis-frontend/**/*.html"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/genesis-frontend"],
      "options": {
        "jestConfig": "apps/genesis-frontend/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": []
}
