{
  "name": "cubes-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "HAUS HOPPE — Ordinal Cubes frontend (cubes.haushoppe.art). Permissionless 3D Bitcoin cube gallery.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:regtest": "ng serve -c regtest",
    "build": "ng build",
    "lint": "eslint 'src/**/*.ts'",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:regtest": "playwright test --config e2e/regtest/playwright.config.ts",
    "e2e:regtest:up": "docker compose -f e2e/regtest/docker-compose.regtest.yml up -d bitcoind electrs && bash e2e/regtest/regtest-bootstrap.sh",
    "e2e:regtest:down": "docker compose -f e2e/regtest/docker-compose.regtest.yml down -v",
    "test": "ng test"
  },
  "dependencies": {
    "@angular/animations": "21.2.17",
    "@angular/common": "21.2.17",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.17",
    "@angular/forms": "21.2.17",
    "@angular/localize": "21.2.17",
    "@angular/platform-browser": "21.2.17",
    "@angular/platform-browser-dynamic": "21.2.17",
    "@angular/router": "21.2.17",
    "@fontsource/inter": "^5.0.8",
    "@fontsource/merriweather": "^4.5.14",
    "@fontsource/yantramanav": "^4.5.9",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@ngrx/effects": "21.1.1",
    "@ngrx/operators": "^18.0.0",
    "@ngrx/router-store": "21.1.1",
    "@ngrx/store": "21.1.1",
    "@ngrx/store-devtools": "21.1.1",
    "@noble/curves": "^1.4.0",
    "@popperjs/core": "^2.11.8",
    "@scure/base": "^1.1.0",
    "@scure/btc-signer": "1.2.x",
    "angularx-qrcode": "^21.0.5",
    "bignumber.js": "^9.1.2",
    "bitcoin-address-validation": "^2.2.1",
    "bootstrap": "^5.3.1",
    "bootstrap-icons": "^1.10.5",
    "buffer": "^6.0.3",
    "canvas-confetti": "^1.6.0",
    "marked": "^4.2.12",
    "ngrx-store-localstorage": "^20.1.0",
    "ordpool-sdk": "github:ordpool-space/ordpool-sdk#79a2bd8",
    "process": "^0.11.10",
    "reflect-metadata": "^0.1.13",
    "rxjs": "~7.8.0",
    "sats-connect": "^4.0.0",
    "tslib": "^2.3.0",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.16",
    "@angular/cli": "21.2.16",
    "@angular/compiler-cli": "21.2.17",
    "@playwright/test": "^1.61.0",
    "@types/canvas-confetti": "^1.6.0",
    "@types/marked": "^5.0.1",
    "@types/node": "^18.11.18",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "eslint": "8.46.0",
    "jsdom": "^25.0.0",
    "typescript": "5.9.3",
    "vitest": "^3.0.0"
  }
}
