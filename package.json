    "@angular-eslint/template-parser": "15.0.0",
    "@angular/cli": "~15.0.0",
    "@angular/compiler-cli": "15.0.4",
    "@angular/language-service": "15.0.4",
    "@nestjs/schematics": "^9.0.4",
    "@nestjs/testing": "^9.2.1",
    "@nrwl/angular": "15.4.4",
    "@nrwl/cli": "15.4.4",
    "@nrwl/eslint-plugin-nx": "15.4.4",
    "@nrwl/jest": "15.4.4",
    "@nrwl/linter": "15.4.4",
    "@nrwl/nest": "15.4.4",
    "@nrwl/node": "15.4.4",
    "@nrwl/workspace": "15.4.4",
    "@types/jest": "^29.2.5",
    "@types/node": "^18.11.18",
