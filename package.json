{
  "name": "scales-dashboad-workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx run-many --target=serve --projects=backend,frontend",
    "build": "nx run-many --target=build --projects=backend,frontend",
    "test": "nx run-many --target=test --projects=backend,frontend",

    "start:backend": "nx serve --project=backend",
    "build:backend": "nx build --project=backend",
    "build:backend:production": "nx build --project=backend --configuration=production && cp package-backend-compiled.json dist/apps/backend/package.json",
    "test:backend": "nx test --project=backend",

    "start:frontend": "nx serve --project=frontend",
    "build:frontend": "nx build --project=frontend",
    "build:frontend:production": "nx build --project=frontend --configuration=production",
    "test:frontend": "nx test --project=frontend",

    "postinstall": "ngcc --properties es2020 browser module main"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~14.0.0",
    "@angular/common": "~14.0.0",
    "@angular/compiler": "~14.0.0",
    "@angular/core": "~14.0.0",
    "@angular/forms": "~14.0.0",
    "@angular/platform-browser": "~14.0.0",
    "@angular/platform-browser-dynamic": "~14.0.0",
    "@angular/router": "~14.0.0",
    "@nestjs/common": "^8.0.0",
    "@nestjs/config": "^2.0.0",
    "@nestjs/core": "^8.0.0",
    "@nestjs/platform-express": "^8.0.0",
    "@nestjs/serve-static": "^2.2.2",
    "@nestjs/swagger": "^5.2.1",
    "axios": "^0.27.2",
    "joi": "^17.6.0",
    "mongodb": "^4.7.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0",
    "swagger-ui-express": "^4.3.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~14.0.0",
    "@angular-devkit/schematics": "^14.0.5",
    "@angular-eslint/eslint-plugin": "~14.0.0",
    "@angular-eslint/eslint-plugin-template": "~14.0.0",
    "@angular-eslint/template-parser": "~14.0.0",
    "@angular/cli": "~14.0.0",
    "@angular/compiler-cli": "~14.0.0",
    "@angular/language-service": "~14.0.0",
    "@nestjs/schematics": "^8.0.0",
    "@nestjs/testing": "^8.0.0",
    "@nrwl/angular": "^14.4.2",
    "@nrwl/cli": "14.4.2",
    "@nrwl/eslint-plugin-nx": "14.4.2",
    "@nrwl/jest": "14.4.2",
    "@nrwl/linter": "14.4.2",
    "@nrwl/nest": "14.4.2",
    "@nrwl/node": "14.4.2",
    "@nrwl/workspace": "14.4.2",
    "@types/jest": "27.4.1",
    "@types/node": "18.0.0",
    "@typescript-eslint/eslint-plugin": "5.30.6",
    "@typescript-eslint/parser": "5.30.6",
    "eslint": "8.15.0",
    "eslint-config-prettier": "8.1.0",
    "jest": "27.5.1",
    "jest-preset-angular": "~11.1.2",
    "nx": "14.4.2",
    "prettier": "2.7.1",
    "ts-jest": "27.1.4",
    "ts-node": "10.8.2",
    "typescript": "4.7.4"
  }
}
