{
  "name": "nft-monorepo",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx run-many --target=serve --projects=backend,scales-dashboard-frontend",
    "build": "nx run-many --target=build --projects=backend,scales-dashboard-frontend",
    "test": "nx run-many --target=test --projects=backend,scales-dashboard-frontend",
    "start:backend": "nx serve --project=backend",
    "build:backend": "nx build --project=backend",
    "build:backend:production": "nx build --project=backend --configuration=production && cp package-backend-compiled.json dist/apps/backend/package.json",
    "test:backend": "nx test --project=backend",
    "start:scales-dashboard-frontend": "nx serve --project=scales-dashboard-frontend",
    "build:scales-dashboard-frontend": "nx build --project=scales-dashboard-frontend",
    "build:scales-dashboard-frontend:production": "nx build --project=scales-dashboard-frontend --configuration=production",
    "test:scales-dashboard-frontend": "nx test --project=scales-dashboard-frontend",
    "postinstall": "ngcc --properties es2020 browser module main"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "15.0.4",
    "@angular/common": "15.0.4",
    "@angular/compiler": "15.0.4",
    "@angular/core": "15.0.4",
    "@angular/forms": "15.0.4",
    "@angular/platform-browser": "15.0.4",
    "@angular/platform-browser-dynamic": "15.0.4",
    "@angular/router": "15.0.4",
    "@nestjs/common": "^9.2.1",
    "@nestjs/config": "^2.2.0",
    "@nestjs/core": "^9.2.1",
    "@nestjs/mongoose": "^9.2.1",
    "@nestjs/platform-express": "^9.2.1",
    "@nestjs/serve-static": "^3.0.0",
    "@nestjs/swagger": "^6.1.4",
    "@types/papaparse": "^5.3.7",
    "axios": "^0.27.2",
    "bootstrap": "^5.2.3",
    "ethers": "^5.7.2",
    "joi": "^17.7.0",
    "mongodb": "^4.13.0",
    "mongoose": "^6.8.3",
    "papaparse": "^5.3.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "~7.8.0",
    "swagger-ui-express": "^4.6.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "15.0.4",
    "@angular-devkit/schematics": "15.0.4",
