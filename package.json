{
  "name": "scales-dashboad-workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx run-many --target=serve --projects=backend,frontend",
    "build": "nx run-many --target=build --projects=backend,frontend",
    "test": "nx run-many --target=test --projects=backend,frontend",
    "start:backend": "nx serve --project=backend",
    "build:backend": "nx build --project=backend",
    "build:backend:production": "nx build --project=backend --configuration=production && cp package-backend-compiled.json dist/apps/backend/package.json",
    "test:backend": "nx test --project=backend",
    "start:frontend": "nx serve --project=frontend",
    "build:frontend": "nx build --project=frontend",
    "build:frontend:production": "nx build --project=frontend --configuration=production",
    "test:frontend": "nx test --project=frontend",
    "postinstall": "ngcc --properties es2020 browser module main"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "15.0.4",
    "@angular/common": "15.0.4",
    "@angular/compiler": "15.0.4",
    "@angular/core": "15.0.4",
    "@angular/forms": "15.0.4",
    "@angular/platform-browser": "15.0.4",
    "@angular/platform-browser-dynamic": "15.0.4",
    "@angular/router": "15.0.4",
    "@nestjs/common": "9.2.1",
    "@nestjs/config": "^2.0.0",
    "@nestjs/core": "9.2.1",
    "@nestjs/platform-express": "9.2.1",
    "@nestjs/serve-static": "^2.2.2",
    "@nestjs/swagger": "6.1.4",
    "axios": "^0.27.2",
    "bootstrap": "^5.1.3",
    "joi": "^17.6.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "~7.5.0",
    "swagger-ui-express": "^4.3.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "15.0.4",
    "@angular-devkit/schematics": "15.0.4",
    "@angular-eslint/eslint-plugin": "15.0.0",
    "@angular-eslint/eslint-plugin-template": "15.0.0",
    "@angular-eslint/template-parser": "15.0.0",
    "@angular/cli": "~15.0.0",
    "@angular/compiler-cli": "15.0.4",
    "@angular/language-service": "15.0.4",
    "@nestjs/schematics": "9.0.4",
    "@nestjs/testing": "9.2.1",
    "@nrwl/angular": "15.4.4",
    "@nrwl/cli": "15.4.4",
    "@nrwl/eslint-plugin-nx": "15.4.4",
    "@nrwl/jest": "15.4.4",
    "@nrwl/linter": "15.4.4",
    "@nrwl/nest": "15.4.4",
    "@nrwl/node": "15.4.4",
    "@nrwl/workspace": "15.4.4",
    "@types/jest": "28.1.8",
    "@types/node": "18.7.1",
    "@typescript-eslint/eslint-plugin": "5.48.0",
    "@typescript-eslint/parser": "5.48.0",
    "eslint": "8.15.0",
    "eslint-config-prettier": "8.1.0",
    "jest": "28.1.3",
    "jest-environment-jsdom": "28.1.1",
    "jest-preset-angular": "12.2.3",
    "nx": "15.4.4",
    "prettier": "2.7.1",
    "ts-jest": "28.0.8",
    "ts-node": "10.9.1",
    "typescript": "4.8.4"
  }
